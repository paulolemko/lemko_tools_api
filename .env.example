# Copy this file to .env and adjust values for your environment.
# .env is intentionally ignored by Git.

# -----------------------------------------------------------------------------
# Compose / PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me
LEMSLOWNIK_DB_NAME=lemslownik
DATABASE_URL=postgres://postgres:change-me@postgres:5432/lemslownik

# -----------------------------------------------------------------------------
# API auth and CORS
# -----------------------------------------------------------------------------
# Set PRODUCTION_MODE=1 for public deployments. Production mode requires a
# non-empty JWT_SECRET, explicit CORS_ALLOW_ORIGINS without "*", a positive
# MAX_AUDIO_SECONDS value, hidden internal error details, and rate limiting.
PRODUCTION_MODE=0
ENVIRONMENT=development

# If empty in development, /v1 endpoints are public. In production this must
# be non-empty. Use Authorization: Bearer <value>.
JWT_SECRET=change-me
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=1
TRUST_PROXY_HEADERS=0

# Production example:
# PRODUCTION_MODE=1
# ENVIRONMENT=production
# JWT_SECRET=replace-with-long-random-token
# CORS_ALLOW_ORIGINS=https://lemko.tools,https://www.lemko.tools
# CORS_ALLOW_CREDENTIALS=0
# TRUST_PROXY_HEADERS=1

# In production rate limiting is always enabled. In development, set
# RATE_LIMIT_ENABLED=1 to test it locally.
RATE_LIMIT_ENABLED=0
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# ASR model and transcription limits
# -----------------------------------------------------------------------------
MODEL_PATH=/app/models/epoch6-step4571_CAPS_WER8.nemo
TARGET_SR=16000
BEAM_SIZE=8
MAX_SYMBOLS_PER_STEP=32
MAX_UPLOAD_MB=200
MAX_AUDIO_SECONDS=7200
MAX_CONCURRENCY=1

# Chunking by audio envelope
MIN_CHUNK_S=15
MAX_CHUNK_S=25
ENV_WIN_MS=50
SILENCE_Q=0.25
SILENCE_FACTOR=1.0

# -----------------------------------------------------------------------------
# Persistent paths
# -----------------------------------------------------------------------------
TRANS_DIR=/app/logs/transkrypcje
LOG_PATH=/app/logs/log.json
TRANSCRIPTED_SOURCE_DIR=/app/logs/transcripted_source
TRANSCRIPTIONS_CSV_PATH=/app/logs/transcriptions_log.csv
LEM_SEARCH_LOG_PATH=/app/logs/lemko_search_log.csv
LEM_TRANSLATE_LOG_PATH=/app/logs/lemko_translate_log.csv
LEM_TTS_LOG_PATH=/app/logs/lemko_tts_log.csv

# -----------------------------------------------------------------------------
# Morphology and FastText search
# -----------------------------------------------------------------------------
MORPHOLOGY_STRUCTURE_FILE=/app/morphology_structure_pl_lem_eng/morphology_structure_lem01.json
VOCAB_JSON_DIR=/app/vocab_json
FASTTEXT_MODEL_DIR=/app/models

LEM_SEARCH_ENABLED=1
LEM_SEARCH_SIMILAR_LIMIT=10
LEM_SEARCH_SIMILAR_LANG=lem
LEM_SEARCH_SIMILAR_DEBUG=0

LEM_PL_SEARCH_SUGGEST_LIMIT=15
LEM_PL_SEARCH_NO_SUGGEST=0
LEM_PL_SEARCH_SUGGEST_DEBUG=0
LEM_PL_SEARCH_LLM_MODEL=gpt-5-mini
LEM_PL_SEARCH_LLM_DEBUG=0

LEM_EN_SEARCH_SUGGEST_LIMIT=15
LEM_EN_SEARCH_NO_SUGGEST=0
LEM_EN_SEARCH_SUGGEST_DEBUG=0
LEM_EN_SEARCH_LLM_MODEL=gpt-5-mini
LEM_EN_SEARCH_LLM_DEBUG=0

# -----------------------------------------------------------------------------
# OpenAI translation
# -----------------------------------------------------------------------------
LEM_TRANSLATE_ENABLED=1
LEM_TRANSLATE_MODEL=gpt-5
# OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# LEM_TRANSLATE_SERVICE_TIER=priority

# Optional second stage for Lemko -> Polish -> target language translation.
# If target_lang is not PL, /v1/lemko/translate/pl uses DeepL from Polish to
# the requested DeepL target language.
# DEEPL_AUTH_KEY=...
# DEEPL_AUTH_KEY_FILE=/run/secrets/deepl_auth_key
# DEEPL_API_BASE_URL=https://api.deepl.com/v2
DEEPL_TIMEOUT_SECONDS=30
DEEPL_LANG_CACHE_TTL_SECONDS=3600

# Optional separate database URL for lem_translate.py.
# LEM_TRANSLATE_DATABASE_URL=postgres://postgres:change-me@postgres:5432/lemslownik

# ---------------------------------------------------------------------------
# Polish -> Lemko translation
# ---------------------------------------------------------------------------
PL_LEM_TRANSLATE_ENABLED=1
PL_LEM_TRANSLATE_API_BASE=http://127.0.0.1:8000
PL_LEM_TRANSLATE_RULES_DIR=/app/docs/structured_rules
PL_LEM_TRANSLATE_CODEX_BIN=/usr/local/bin/codex
PL_LEM_TRANSLATE_CODEX_TIMEOUT_SECONDS=900
PL_LEM_TRANSLATE_MAX_CHARS=1600
PL_LEM_TRANSLATE_MAX_TERMS=30
PL_LEM_TRANSLATE_MAX_MEMORY_EXAMPLES=3
PL_LEM_TRANSLATE_MEMORY_MIN_SCORE=0.08
PL_LEM_TRANSLATE_MEMORY_PROFILE_SCORING=0
PL_LEM_TRANSLATE_MEMORY_RISK_POLICY=include
# Optional explicit token for the internal dictionary API. If unset and
# PL_LEM_TRANSLATE_API_BASE points to this service, JWT_SECRET is reused.
# PL_LEM_TRANSLATE_API_TOKEN=...

# -----------------------------------------------------------------------------
# StyleTTS2
# -----------------------------------------------------------------------------
STYLE_TTS2_DIR=/app/models/StyleTTS2
STYLE_TTS2_REFS_ROOT=/app/models/StyleTTS2
STYLE_TTS2_PHONEMIZER_PL=pl
STYLE_TTS2_PHONEMIZER_UK=uk
STYLE_TTS2_PHONEMIZER_BG=bg

MAX_TTS_CONCURRENCY=1
TTS_MAX_WORKERS=1
TTS_TEXT_MAX_CHARS=1000
TTS_NUM_REFS=3
TTS_TRIM_IN_MS=100
TTS_TRIM_OUT_MS=200
